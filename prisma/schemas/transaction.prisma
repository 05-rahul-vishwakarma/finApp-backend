// prisma/schemas/transaction.prisma

model Transaction {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  uploadId          String?  @map("upload_id")
  categoryId        String?  @map("category_id")
  description       String   @db.Text
  amount            Decimal  @db.Decimal(12, 2)
  type              String   @db.VarChar(10)
  transactionDate   DateTime
  transactionTime   DateTime?
  referenceNumber   String?  @db.VarChar(100)
  originalDescription String? @db.Text
  merchantName      String?  @db.VarChar(255)
  isManual          Boolean  @default(false)
  isVerified        Boolean  @default(false)
  isDuplicate       Boolean  @default(false)
  notes             String?  @db.Text
  tags              String[]
  location          String?  @db.VarChar(255)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  upload   Upload?  @relation(fields: [uploadId], references: [id], onDelete: SetNull)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([userId, referenceNumber])
  @@index([userId])
  @@index([uploadId])
  @@index([categoryId])
  @@index([transactionDate(sort: Desc)])
  @@index([type])
  @@map("transactions")
}