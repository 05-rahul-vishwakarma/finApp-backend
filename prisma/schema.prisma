// prisma/schema.prisma
// Merged Prisma schema. Individual model files under prisma/schemas/ are no longer required.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole{
  user
  admin
}

model User {
  id                String   @id @default(cuid())
  phoneNumber       String   @unique @db.VarChar(15)
  email             String?  @unique @db.VarChar(255)
  fullName          String   @db.VarChar(100)
  password          String   @db.VarChar(255)
  profilePictureUrl String?
  role              UserRole @default(user)
  monthlyIncome     Decimal? @default(0) @db.Decimal(12, 2)
  currencyCode      String   @default("INR") @db.VarChar(3)
  isVerified        Boolean  @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  lastLoginAt       DateTime?
  deletedAt         DateTime?

  otps              OtpVerification[]
  uploads           Upload[]
  transactions      Transaction[]
  budgets           Budget[]
  notifications     Notification[]
  sessions          UserSession[]
  settings          UserSetting?
  categories        Category[]

  @@index([phoneNumber])
  @@index([email])
  @@index([isActive])
}

model Transaction {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id")
  uploadId            String?  @map("upload_id")
  categoryId          String?  @map("category_id")
  description         String   @db.Text
  amount              Decimal  @db.Decimal(12, 2)
  type                String   @db.VarChar(10)
  transactionDate     DateTime
  transactionTime     DateTime?
  referenceNumber     String?  @db.VarChar(100)
  originalDescription String?  @db.Text
  merchantName        String?  @db.VarChar(255)
  isManual            Boolean  @default(false)
  isVerified          Boolean  @default(false)
  isDuplicate         Boolean  @default(false)
  notes               String?  @db.Text
  tags                String[]
  location            String?  @db.VarChar(255)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  upload   Upload?  @relation(fields: [uploadId], references: [id], onDelete: SetNull)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([userId, referenceNumber])
  @@index([userId])
  @@index([uploadId])
  @@index([categoryId])
  @@index([transactionDate(sort: Desc)])
  @@index([type])
  @@map("transactions")
}

model Category {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(50)
  icon        String?  @db.VarChar(50)
  color       String   @default("#808080") @db.VarChar(7)
  type        String   @db.VarChar(10)
  isDefault   Boolean  @default(false)
  userId      String?  @map("user_id")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets     Budget[]

  @@unique([userId, name])
  @@unique([name])
  @@index([type])
  @@index([userId])
  @@map("categories")
}

model Budget {
  id                    String   @id @default(cuid())
  userId                String   @map("user_id")
  categoryId            String   @map("category_id")
  month                 DateTime
  amount                Decimal  @db.Decimal(12, 2)
  spentAmount           Decimal  @default(0) @db.Decimal(12, 2)
  isAlertSent           Boolean  @default(false)
  alertThresholdPercent Int      @default(80)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, month])
  @@index([userId])
  @@index([month])
  @@index([userId, month])
  @@map("budgets")
}

model OtpVerification {
  id          String   @id @default(cuid())
  userId      String?  @map("user_id")
  phoneNumber String   @db.VarChar(15)
  otpCode     String   @db.VarChar(6)
  purpose     String   @default("login") @db.VarChar(20)
  isUsed      Boolean  @default(false)
  attempts    Int      @default(0)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phoneNumber])
  @@index([userId])
  @@index([expiresAt])
  @@map("otp_verifications")
}

model Upload {
  id                   String   @id @default(cuid())
  userId               String   @map("user_id")
  fileName             String   @db.VarChar(255)
  filePath             String   @db.Text
  fileSize             Int?
  fileType             String?  @db.VarChar(20)
  fileHash             String?  @db.VarChar(64)
  bankName             String?  @db.VarChar(100)
  accountNumber        String?  @db.VarChar(30)
  accountHolderName    String?  @db.VarChar(100)
  statementPeriodStart DateTime?
  statementPeriodEnd   DateTime?
  totalTransactions    Int      @default(0)
  totalCredits         Decimal? @default(0) @db.Decimal(12, 2)
  totalDebits          Decimal? @default(0) @db.Decimal(12, 2)
  openingBalance       Decimal? @db.Decimal(12, 2)
  closingBalance       Decimal? @db.Decimal(12, 2)
  status               String   @default("pending") @db.VarChar(20)
  errorMessage         String?  @db.Text
  processingDurationMs Int?
  uploadedAt           DateTime @default(now())
  processedAt          DateTime?
  updatedAt            DateTime @updatedAt
  isDeleted            Boolean  @default(false)
  deletedAt            DateTime?

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([userId, fileHash])
  @@index([userId])
  @@index([status])
  @@index([uploadedAt])
  @@map("uploads")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String   @db.VarChar(30)
  title     String   @db.VarChar(255)
  message   String   @db.Text
  data      Json?
  isRead    Boolean  @default(false)
  isClicked Boolean  @default(false)
  priority  String   @default("normal") @db.VarChar(10)
  createdAt DateTime @default(now())
  readAt    DateTime?
  clickedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

model UserSession {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  refreshToken   String   @db.Text
  deviceId       String   @db.VarChar(255)
  deviceName     String?  @db.VarChar(100)
  deviceType     String?  @db.VarChar(20)
  ipAddress      String?  @db.VarChar(45)
  userAgent      String?  @db.Text
  isActive       Boolean  @default(true)
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  lastAccessedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
  @@index([expiresAt])
  @@map("user_sessions")
}

model UserSetting {
  userId               String   @id @map("user_id")
  darkMode             Boolean  @default(false)
  currency             String   @default("INR") @db.VarChar(3)
  language             String   @default("en") @db.VarChar(10)
  dateFormat           String   @default("DD/MM/YYYY") @db.VarChar(20)
  notificationsEnabled Boolean  @default(true)
  emailNotifications   Boolean  @default(true)
  pushNotifications    Boolean  @default(true)
  budgetAlertsEnabled  Boolean  @default(true)
  autoCategorize       Boolean  @default(true)
  privacyMode          Boolean  @default(false)
  biometricEnabled     Boolean  @default(false)
  sessionTimeout       Int      @default(30)
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}
